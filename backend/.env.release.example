APP_ENV=release
APP_NAME=Eden ERP Backend
APP_VERSION=0.1.0

DATABASE_URL=<release-supabase-pooler-or-direct-db-url>
SUPABASE_URL=<release-supabase-url>
SUPABASE_PROJECT_REF=<release-project-ref>
SUPABASE_JWT_SECRET=<release-supabase-jwt-secret>
SUPABASE_JWKS_URL=<release-supabase-url>/auth/v1/.well-known/jwks.json

AUTH_REQUIRED=true
ALLOW_TRUSTED_PROXY_HEADERS=false
TRUSTED_PROXY_SECRET=<release-proxy-secret>
INTERNAL_BACKEND_TOKEN=<release-internal-token>
CORS_ALLOWED_ORIGINS=<release-vercel-url>

LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_ENABLED=true
ERROR_TRACKING_ENABLED=true
SENTRY_DSN=<release-sentry-dsn-if-used>

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_STATEMENT_TIMEOUT_MS=1500
DB_SLOW_QUERY_MS=750
USE_SUPABASE_POOLER=true
WORKER_DB_POOL_SIZE=2

OUTBOX_BATCH_SIZE=25
OUTBOX_POLL_INTERVAL_SECONDS=5
OUTBOX_MAX_RUNTIME_MS=25000
OUTBOX_LOCK_TTL_SECONDS=300
OUTBOX_MAX_RETRIES=5
WORKER_ID=eden-worker-release
