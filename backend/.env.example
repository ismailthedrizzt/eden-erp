# Eden ERP FastAPI backend environment example.
# Copy to backend/.env for local backend runs. Never commit real secrets.

APP_ENV=local
APP_NAME=Eden ERP Backend
APP_VERSION=0.1.0

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

AUTH_REQUIRED=false
ALLOW_TRUSTED_PROXY_HEADERS=true
TRUSTED_PROXY_SECRET=replace-with-shared-proxy-secret
INTERNAL_BACKEND_TOKEN=replace-with-shared-internal-token
CORS_ALLOWED_ORIGINS=http://localhost:3000

LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_ENABLED=true
ERROR_TRACKING_ENABLED=false
SENTRY_DSN=

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_STATEMENT_TIMEOUT_MS=1500
DB_SLOW_QUERY_MS=750
USE_SUPABASE_POOLER=false
WORKER_DB_POOL_SIZE=

API_SLOW_REQUEST_MS=1000
API_VERY_SLOW_REQUEST_MS=3000
EXPOSE_RESPONSE_TIME_HEADER=true

OUTBOX_BATCH_SIZE=25
OUTBOX_POLL_INTERVAL_SECONDS=5
OUTBOX_MAX_RUNTIME_MS=25000
OUTBOX_LOCK_TTL_SECONDS=300
OUTBOX_MAX_RETRIES=5
WORKER_ID=eden-worker-local
