{
  "name": "eden-erp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run validate:contracts && npm run encoding:guard && npm run backend:boundary:enforce && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "npm run typecheck:local",
    "typecheck:local": "npm run typecheck:shared && npm run typecheck:fast",
    "typecheck:app": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:shared": "tsc --noEmit -p tsconfig.shared.json",
    "typecheck:fast": "node scripts/typecheck-targeted.js",
    "typecheck:fast:all": "node scripts/typecheck-targeted.js --include-untracked",
    "typecheck:ci": "npm run typecheck:shared && npm run typecheck:app",
    "typecheck:full": "tsc --noEmit -p tsconfig.typecheck.json",
    "backend:dev": "cd backend && .venv/bin/python -m uvicorn app.main:app --reload",
    "backend:test": "cd backend && .venv/bin/python -m pytest",
    "backend:lint": "cd backend && .venv/bin/python -m ruff check .",
    "backend:typecheck": "cd backend && .venv/bin/python -m mypy app",
    "backend:format": "cd backend && .venv/bin/python -m ruff format .",
    "openapi:export": "cd backend && .venv/bin/python scripts/export_openapi.py",
    "openapi:generate": "openapi-typescript backend/openapi.json -o lib/generated/backend-client/types.ts && node scripts/mark-generated-openapi-client.js",
    "openapi:refresh": "npm run openapi:export && npm run openapi:generate",
    "openapi:drift": "npm run openapi:refresh && git diff --exit-code backend/openapi.json lib/generated/backend-client/types.ts",
    "page-flow:contract:check": "node scripts/check-page-flow-contracts.js",
    "frontend:standard:check": "node scripts/check-frontend-standard-contracts.js",
    "contracts:check": "node scripts/check-contract-standardization.js",
    "test:contracts": "npm run contracts:check",
    "validate:contracts": "npm run contracts:check && npm run page-flow:contract:check && npm run frontend:standard:check && npm run release:check",
    "eden:quality-gate": "node scripts/eden-quality-gate.js",
    "demo:seed": "node scripts/check-database-target.js demo:seed && cd backend && .venv/bin/python scripts/seed_demo.py",
    "demo:seed:dry": "node scripts/check-database-target.js demo:seed:dry && cd backend && .venv/bin/python scripts/seed_demo.py --dry-run",
    "demo:validate": "backend/.venv/bin/python backend/scripts/validate_demo_data.py",
    "migration:status": "node scripts/check-backend-migration-status.js",
    "migration:inventory": "node scripts/check-backend-migration-status.js write-inventory",
    "proxy:coverage": "node scripts/check-backend-migration-status.js write-proxy-matrix",
    "nextapi:burndown": "node scripts/generate-next-api-burndown-docs.js",
    "ts-backend:inventory": "node scripts/generate-remaining-ts-backend-inventory.js",
    "backend:boundary:audit": "node scripts/audit-next-backend-boundary.js",
    "backend:boundary:enforce": "node scripts/audit-next-backend-boundary.js --fail-on-direct-db",
    "boundaries:check": "node scripts/check-import-boundaries.js",
    "release:check": "node scripts/check-release-registry.js",
    "theme:hikmet:generate": "node scripts/generate-hikmet-theme-package.mjs",
    "theme:hikmet:validate": "node scripts/validate-hikmet-theme-package.mjs",
    "env:safety": "node scripts/check-release-env-safety.js",
    "db:target:check": "node scripts/check-database-target.js",
    "db:migrate:check": "COMMAND_CONTEXT=migration node scripts/check-database-target.js",
    "db:seed:check": "COMMAND_CONTEXT=seed node scripts/check-database-target.js",
    "db:reset:check": "COMMAND_CONTEXT=reset node scripts/check-database-target.js",
    "db:migrate": "npm run db:migrate:check && cd backend && .venv/bin/alembic upgrade head",
    "db:reset:development": "COMMAND_CONTEXT=reset node scripts/check-database-target.js && node scripts/reset-public-schema.js",
    "smoke:test": "node scripts/smoke-test.js",
    "smoke:test:dry": "node scripts/smoke-test.js --dry-run=true",
    "check:all": "npm run typecheck && npm run build && node -e \"console.log('Backend checks: run npm run backend:lint && npm run backend:typecheck && npm run backend:test after installing backend dependencies')\"",
    "encoding:guard": "node scripts/check-source-encoding.js",
    "security:guard": "node scripts/check-security-reference-contracts.js",
    "perf:guard": "npm run encoding:guard && node scripts/check-performance-contracts.js",
    "load:test": "node scripts/load-test.js",
    "load:test:smoke": "node scripts/load-test.js --duration=5 --connections=5",
    "load:test:scenarios": "node scripts/load-test.js --list=true",
    "load:test:company-list": "node scripts/load-test.js --scenario=company-list --duration=10 --connections=10",
    "load:test:platform-smoke": "node scripts/load-test.js --scenario=platform-smoke --duration=5 --connections=5",
    "ollama:install:windows": "powershell -ExecutionPolicy Bypass -File scripts/install-ollama-release.ps1",
    "ollama:install:release": "powershell -ExecutionPolicy Bypass -File scripts/install-ollama-release.ps1",
    "ollama:install:vps": "bash scripts/install-ollama-vps.sh",
    "ollama:serve": "powershell -ExecutionPolicy Bypass -File scripts/start-ollama-local.ps1",
    "ollama:pull": "powershell -ExecutionPolicy Bypass -File scripts/install-ollama-release.ps1 -PullModel",
    "clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\"",
    "iban:banks": "node --use-system-ca scripts/update-turkish-bank-codes.js",
    "iban:ziraat-branches": "node --use-system-ca scripts/update-ziraat-branches.js",
    "iban:garanti-branches": "node --use-system-ca scripts/update-garanti-bbva-branches.js",
    "iban:isbank-branches": "node --use-system-ca scripts/update-isbank-branches.js",
    "reference:locations": "node scripts/update-turkey-locations.js",
    "reference:tax-offices": "node scripts/update-tax-offices.js",
    "reference:nace-codes": "node --use-system-ca scripts/update-nace-codes.js"
  },
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.6.0",
    "@supabase/ssr": "^0.4.0",
    "@supabase/supabase-js": "^2.43.5",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "i18n-iso-countries": "^7.14.0",
    "lucide-react": "^0.471.0",
    "mammoth": "^1.12.0",
    "next": "15.5.15",
    "next-pwa": "^5.6.0",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.296",
    "pg": "^8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.51.5",
    "recharts": "^2.12.7",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autocannon": "^8.0.0",
    "autoprefixer": "^10.4.19",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.15",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5"
  }
}
