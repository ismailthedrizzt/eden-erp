{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "build": {
    "env": {
      "NEXT_PUBLIC_VERCEL_URL": "$VERCEL_URL"
    }
  },
  "crons": [
    {
      "path": "/api/cron/update-reference-data",
      "schedule": "0 0 * * 0"
    }
  ]
}
