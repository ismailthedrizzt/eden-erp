# ================================================================
# EDEN ERP - Environment Variables
# Bu dosyayi .env.local olarak kopyalayip kendi Supabase degerlerinizi girin
# ================================================================

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
# Not: URL alanina /rest/v1 degil dogrudan proje URL'si yazilir.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role (sadece sunucu tarafinda, asla frontend'e acma)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Uygulama
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Eden Teknoloji ERP
# Vercel production/preview icin bu degeri localhost birakmayin.
# Ayrik FastAPI backend yoksa Vercel'de NEXT_PUBLIC_API_BASE_URL tanimlamayin.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# FastAPI backend (server only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
DEFAULT_INSTANCE_ID=00000000-0000-0000-0000-000000000000
CORS_ORIGINS=http://localhost:3000

# Tenancy foundation (passive until the activation flags are enabled)
EDEN_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000
EDEN_TENANCY_ISOLATION_MODE=shared_schema
EDEN_TENANT_COLUMN_WRITES=false
EDEN_TENANT_FILTERING=false
EDEN_TENANT_DATABASE_ROUTING=false

# CV -> çalışan alanı çıkarımı için ücretsiz Gemini API anahtarı
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview

# Vercel Cron güvenliği
CRON_SECRET=change-this-cron-secret

# Eden Mail API (server only, frontend'e acma)
EDEN_MAIL_API_KEY=your-eden-mail-api-key

# E-posta OTP imzalama anahtari (server only)
OTP_SECRET=change-this-otp-secret

# OTP/SMS (ileride Twilio veya Supabase Auth ile entegre edilecek)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Garanti BBVA API sandbox credential (server only)
# credential_id alanına GARANTI_SANDBOX yazıldığında backend bu değişkeni okur.
# Consent onayı geldikten sonra consentId doldurulmalı; token testi consentId olmadan da çalışır.
BANK_CREDENTIAL_GARANTI_SANDBOX={"clientId":"your-garanti-client-id","clientSecret":"your-garanti-client-secret","redirectUri":"https://your-callback-url.example/tokenendpoint","consentId":"","tokenEndpoint":"https://apis.garantibbva.com.tr:443/auth/oauth/v2/token","apiBaseUrl":"https://apis.garantibbva.com.tr:443","scopes":["oob"],"extra":{"tokenAuthMethod":"body"}}
