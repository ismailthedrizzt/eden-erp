# ================================================================
# EDEN ERP - Environment Variables
# Bu dosyayi .env.local olarak kopyalayip kendi Supabase degerlerinizi girin
# ================================================================

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
# Not: URL alanina /rest/v1 degil dogrudan proje URL'si yazilir.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role (sadece sunucu tarafinda, asla frontend'e acma)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Uygulama
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Eden Teknoloji ERP

# CV -> çalışan alanı çıkarımı için ücretsiz Gemini API anahtarı
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview

# Vercel Cron güvenliği
CRON_SECRET=change-this-cron-secret

# OTP/SMS (ileride Twilio veya Supabase Auth ile entegre edilecek)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
