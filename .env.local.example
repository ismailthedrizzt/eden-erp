# Eden ERP local shell example.
# Copy to .env.local only in eden-erp-development for local Next.js commands.
# Do not commit real secrets. Do not put release secrets in .env.local.
# Local DB is not required; development uses the Development Supabase project.

NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_RELEASE_CHANNEL=development
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Eden ERP
NEXT_PUBLIC_ACTION_GUIDE_ENABLED=true
NEXT_PUBLIC_GUIDED_TOUR_ENABLED=true

NEXT_PUBLIC_SUPABASE_URL=<development-supabase-url>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<development-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<development-service-role-key>
SUPABASE_PROJECT_REF=<development-project-ref>
DEVELOPMENT_SUPABASE_URL=<development-supabase-url>
DEVELOPMENT_SUPABASE_PROJECT_REF=<development-project-ref>
RELEASE_SUPABASE_PROJECT_REF=<release-project-ref-for-safety-check>

FASTAPI_BASE_URL=<development-fastapi-url-if-used>
INTERNAL_BACKEND_TOKEN=<development-internal-token>
TRUSTED_PROXY_SECRET=<development-proxy-secret>

EDEN_LOGIN_DISABLED=false
EDEN_ALLOW_LEGACY_API_ACCESS=false
ALLOW_RELEASE_DB_MIGRATION=false
ALLOW_RELEASE_DB_MUTATION=false
ALLOW_RELEASE_DB_SEED=false
ALLOW_RELEASE_DB_RESET=false
RELEASE_MIGRATION_APPROVED_BY=

SUPABASE_URL=<development-supabase-url>
SUPABASE_ANON_KEY=<development-supabase-anon-key>
SUPABASE_JWT_SECRET=<development-jwt-secret>
DATABASE_URL=<development-supabase-pooler-or-direct-db-url-if-needed>
DEFAULT_INSTANCE_ID=00000000-0000-0000-0000-000000000000
CORS_ORIGINS=http://localhost:3000

EDEN_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000
EDEN_TENANCY_ISOLATION_MODE=shared_schema
EDEN_TENANT_COLUMN_WRITES=false
EDEN_TENANT_FILTERING=false
EDEN_TENANT_DATABASE_ROUTING=false

CRON_SECRET=<development-cron-secret>
GEMINI_API_KEY=<development-gemini-key>
GEMINI_MODEL=gemini-3-flash-preview
EDEN_MAIL_API_KEY=<development-mail-key>
OTP_SECRET=<development-otp-secret>
