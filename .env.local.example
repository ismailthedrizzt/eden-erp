# Eden ERP single VS environment example.
# Copy to .env.local for local/VS Next.js commands.
# Do not commit real secrets.

NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_RELEASE_CHANNEL=production
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Eden ERP
NEXT_PUBLIC_ACTION_GUIDE_ENABLED=true
NEXT_PUBLIC_GUIDED_TOUR_ENABLED=true

# The application database target is a single local PostgreSQL database.
DATABASE_URL=postgresql://postgres:<postgres-password>@localhost:5432/app1db

# Optional only if Supabase Auth/API is still used by the deployment.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_PROJECT_REF=

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

FASTAPI_BASE_URL=
INTERNAL_BACKEND_TOKEN=
TRUSTED_PROXY_SECRET=

EDEN_LOGIN_DISABLED=false
EDEN_ALLOW_LEGACY_API_ACCESS=false

DEFAULT_INSTANCE_ID=00000000-0000-0000-0000-000000000000
CORS_ORIGINS=http://localhost:3000

EDEN_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000
EDEN_TENANCY_ISOLATION_MODE=shared_schema
EDEN_TENANT_COLUMN_WRITES=false
EDEN_TENANT_FILTERING=false
EDEN_TENANT_DATABASE_ROUTING=false

CRON_SECRET=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
EDEN_MAIL_API_KEY=
OTP_SECRET=
