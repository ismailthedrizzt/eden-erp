# Eden ERP Next.js local environment example.
# Copy to .env.local and replace placeholders. Never commit real secrets.

# Public app settings
NEXT_PUBLIC_ENVIRONMENT=local
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Eden ERP
NEXT_PUBLIC_ACTION_GUIDE_ENABLED=true
NEXT_PUBLIC_GUIDED_TOUR_ENABLED=true

# Supabase browser client
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# Server-only Supabase access. Never expose through NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# FastAPI BFF proxy target
FASTAPI_BASE_URL=http://localhost:8000
INTERNAL_BACKEND_TOKEN=replace-with-shared-internal-token
TRUSTED_PROXY_SECRET=replace-with-shared-proxy-secret

# Legacy/local migration bridge values
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
DEFAULT_INSTANCE_ID=00000000-0000-0000-0000-000000000000
CORS_ORIGINS=http://localhost:3000

# Tenancy defaults for local development only
EDEN_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000
EDEN_TENANCY_ISOLATION_MODE=shared_schema
EDEN_TENANT_COLUMN_WRITES=false
EDEN_TENANT_FILTERING=false
EDEN_TENANT_DATABASE_ROUTING=false

# Cron/internal endpoints
CRON_SECRET=replace-with-cron-secret

# Optional integrations
GEMINI_API_KEY=replace-with-gemini-key
GEMINI_MODEL=gemini-3-flash-preview
EDEN_MAIL_API_KEY=replace-with-mail-key
OTP_SECRET=replace-with-otp-secret

# Optional banking sandbox secret JSON. Keep server-only.
# BANK_CREDENTIAL_GARANTI_SANDBOX={"clientId":"...","clientSecret":"...","redirectUri":"...","consentId":"","tokenEndpoint":"https://apis.garantibbva.com.tr:443/auth/oauth/v2/token","apiBaseUrl":"https://apis.garantibbva.com.tr:443","scopes":["oob"],"extra":{"tokenAuthMethod":"body"}}
